# App Configuration
APP_NAME=Scanvoca API
APP_VERSION=0.1.0
DEBUG=True

# Database
# Option 1: Supabase PostgreSQL (Production 권장)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Option 2: Local SQLite (Development)
# DATABASE_URL=sqlite:///./scanvoca.db

# Redis
REDIS_URL=redis://localhost:6379

# JWT Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Gemini API (Phase 2)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth (구글 로그인)
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 클라이언트 ID (웹 애플리케이션)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# CORS (React Native Dev Server)
CORS_ORIGINS=["http://localhost:8081","http://localhost:19000"]

# Gmail SMTP (비밀번호 재설정 이메일 발송)
# Gmail 앱 비밀번호 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Scan Voca
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
